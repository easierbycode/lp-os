# LP-OS environment. Copy to .env and fill in.

# Consolidated Postgres (Neon). Single canonical store: inventory + graylog messages.
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Port for the Fresh shell app (apps/shell).
PORT=8000

# Optional: shared ingest token accepted by POST /api/graylog (GELF-compatible ingest).
# Leave empty to accept unauthenticated ingest in local dev.
GRAYLOG_INGEST_TOKEN=

# Optional: auto-list pass interval in ms (fires due auto-list schedules and,
# where opted in, lists cleared_to_sell samples). Default 300000 (5 min).
AUTO_LIST_INTERVAL_MS=

# eBay credentials may be entered in Apps/Marketplace (stored in Postgres) or
# supplied here as server-side fallbacks. Inventory API calls also require a
# seller-authorized refresh token (or a temporary access token); App ID + Cert
# ID alone cannot create offers.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_REFRESH_TOKEN=
# EBAY_ACCESS_TOKEN=
EBAY_ENVIRONMENT=sandbox

# Optional external-API kill switches (on|off). Off wins even when a key or
# credentials are configured; unset falls back to the registry default in
# apps/shell/core/external-apis.ts. barcodelookup defaults OFF (expired key).
EXTERNAL_API_SCRAPECREATORS=
EXTERNAL_API_EBAY=
EXTERNAL_API_BARCODELOOKUP=
