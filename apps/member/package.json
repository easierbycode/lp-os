    "@tailwindcss/vite": "^4.3.1",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.8.3",
    "vite": "^7.3.5"
  },
  "dependencies": {
    "phaser": "^4.0.0"
  }
}
