{
  "manifest_version": 3,
  "name": "LP-OS TikTok Shop Scraper",
  "version": "0.2.0",
  "description": "Merged agency + seller scraper: Partner Center creator/sellers dashboards (partner.us.tiktokshop.com), seller LIVE Dashboard + Streamer Compass (shop.tiktok.com), buyer order pages (www.tiktok.com). Ships GELF to LP-OS. Behaviors are role-gated via the LP-OS shell user.",
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["https://www.tiktok.com/shop/order_detail*"],
      "js": ["scrape-order-main.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "permissions": ["scripting", "activeTab", "tabs", "storage"],
  "host_permissions": [
    "https://thirsty.store/*",
    "https://partner.us.tiktokshop.com/*",
    "https://shop.tiktok.com/*",
    "https://www.tiktok.com/*",
    "https://script.google.com/*",
    "https://*.googleusercontent.com/*",
    "https://*.ngrok-free.dev/*",
    "https://*.ngrok-free.app/*",
    "https://*.ngrok.app/*",
    "https://*.ngrok.io/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "action": {
    "default_title": "LP-OS: scrape this page",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  }
}
